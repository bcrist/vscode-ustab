{
  "name": "ustab",
  "displayName": "US Tables",
  "description": "Unit-Separator Tables",
  "version": "0.1.0",
  "publisher": "bcrist",
  "license": "SEE LICENSE IN license",
  "repository": {
    "type": "git",
    "url": "https://github.com/bcrist/vscode-ustab"
  },
  "engines": {
    "vscode": "^1.125.0"
  },
  "categories": [
    "Formatters",
    "Other"
  ],
  "icon": "./images/icon.png",
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "configuration": {
      "title": "Unit-Separator Tables",
      "type": "object",
      "properties": {
        "ustab.cellSeparator": {
          "description": "The character which separates cells in tables",
          "type": "string",
          "default": "\u001F",
          "enum": [
            "\u0001",
            "\u0002",
            "\u0003",
            "\u001C",
            "\u001D",
            "\u001E",
            "\u001F"
          ],
          "enumItemLabels": [
            "U+0001",
            "U+0002",
            "U+0003",
            "U+001C",
            "U+001D",
            "U+001E",
            "U+001F"
          ],
          "enumDescriptions": [
            "Start of Heading",
            "Start of Text",
            "End of Text",
            "Field Separator",
            "Group Separator",
            "Record Separator",
            "Unit Separator"
          ]
        },
        "ustab.formatOnChange": {
          "description": "Determines whether to automatically reformat tables after documents are modified",
          "type": "string",
          "default": "singleLineOnly",
          "enum": [
            "disabled",
            "singleLineOnly",
            "always"
          ],
          "enumItemLabels": [
            "Disabled",
            "Single line changes only",
            "Always"
          ],
          "enumDescriptions": [
            "Do not automatically format tables when modified",
            "Automatically format tables affected by single-line changes",
            "Automatically format tables affected by single- and multi-line changes"
          ]
        },
        "ustab.bakeString": {
          "description": "The ustab.bakeTable and ustab.bakeAllTables commands will replace cell separators with this string, and the ustab.unbakeTable and ustab.unbakeAllTables commands will replace all occurrences of this string with the cell separator character.",
          "type": "string",
          "default": "|"
        }
      }
    },
    "commands": [
      {
        "command": "ustab.insertCellSeparator",
        "title": "Insert cell separator character"
      },
      {
        "command": "ustab.formatTable",
        "title": "Format selected table(s)"
      },
      {
        "command": "ustab.formatAllTables",
        "title": "Format all tables in document"
      },
      {
        "command": "ustab.bakeTable",
        "title": "Bake all cell separators in the current table"
      },
      {
        "command": "ustab.unbakeTable",
        "title": "Unbake all cell separator in the current table"
      },
      {
        "command": "ustab.bakeAllTables",
        "title": "Bake all cell separators in the current file"
      },
      {
        "command": "ustab.unbakeAllTables",
        "title": "Unbake all cell separators in the current file"
      },
      {
        "command": "ustab.removeCellSeparatorsTable",
        "title": "Remove all unbaked cell separator in the current table"
      },
      {
        "command": "ustab.removeCellSeparatorsAllTables",
        "title": "Remove all unbaked cell separators in the current file"
      },
      {
        "command": "ustab.tab",
        "title": "Move to next table cell or process tab command"
      },
      {
        "command": "ustab.outdent",
        "title": "Move to the previous table cell or process outdent command"
      },
      {
        "command": "ustab.cursorLeft",
        "title": "Move cursor left one character (table aware)"
      },
      {
        "command": "ustab.cursorLeftSelect",
        "title": "Adjust selection left one character (table aware)"
      },
      {
        "command": "ustab.cursorRight",
        "title": "Move cursor right one character (table aware)"
      },
      {
        "command": "ustab.cursorRightSelect",
        "title": "Adjust selection right one character (table aware)"
      }
    ],
    "keybindings": [
      {
        "key": "ctrl+shift+\\",
        "when": "editorTextFocus",
        "command": "ustab.insertCellSeparator"
      },
      {
        "key": "ctrl+k t",
        "when": "editorTextFocus",
        "command": "ustab.formatTable"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "24.x",
    "@types/vscode": "^1.125.0",
    "@vscode/test-cli": "^0.0.15",
    "@vscode/test-electron": "^3.0.0",
    "esbuild": "^0.28.1",
    "eslint": "^10.5.0",
    "npm-run-all": "^4.1.5",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1"
  },
  "overrides": {
    "diff": "^8.0.4",
    "serialize-javascript": "^7.0.6"
  }
}
